{
  "name": "daymate",
  "private": true,
  "version": "0.320.0",
  "type": "module",
  "scripts": {
    "generate:version": "node scripts/generate-version.mjs",
    "predev": "npm run generate:version",
    "prebuild": "npm run generate:version",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tg:start": "powershell -ExecutionPolicy Bypass -File scripts/telegram-agent.ps1 start",
    "tg:stop": "powershell -ExecutionPolicy Bypass -File scripts/telegram-agent.ps1 stop",
    "tg:restart": "powershell -ExecutionPolicy Bypass -File scripts/telegram-agent.ps1 restart",
    "tg:status": "powershell -ExecutionPolicy Bypass -File scripts/telegram-agent.ps1 status",
    "tg:mac:start": "sh scripts/telegram-agent.sh start",
    "tg:mac:stop": "sh scripts/telegram-agent.sh stop",
    "tg:mac:restart": "sh scripts/telegram-agent.sh restart",
    "tg:mac:status": "sh scripts/telegram-agent.sh status",
    "tg:mac:logs": "sh scripts/telegram-agent.sh logs",
    "tg:mac:launchd:install": "sh scripts/telegram-agent.sh install-launchd",
    "tg:mac:launchd:uninstall": "sh scripts/telegram-agent.sh uninstall-launchd",
    "tg:mac:update": "sh scripts/mac-refresh.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "vite": "^7.3.1"
  }
}
